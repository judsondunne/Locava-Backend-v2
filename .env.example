# Copy to .env and fill in values. See AGENTS.md / team docs for secrets.

GCP_PROJECT_ID=
NODE_ENV=development
LOG_LEVEL=info

# Logs per-post media URLs/shape on feed surfaces (heavy). Also accepts LOCAVA_VIDEO_MEDIA_DEBUG=1.
# LOCAVA_FEED_ITEMS_MEDIA_TRACE=1

############################################
# 🎬 VIDEO WORKER (Cloud Tasks POST target)
############################################
# Local-only API: point at yourself (sync / local task emulation if any).
# If your machine enqueues real GCP Cloud Tasks, use your deployed Cloud Run URL + /video-processor.
VIDEO_PROCESSOR_FUNCTION_URL=http://127.0.0.1:8080/video-processor

# Optional: lock down POST /video-processor (Cloud Tasks sends this header when set).
# VIDEO_PROCESSOR_TASK_SECRET=
