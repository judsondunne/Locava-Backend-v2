# Copy to .env and fill in values. See AGENTS.md / team docs for secrets.

GCP_PROJECT_ID=
NODE_ENV=development
LOG_LEVEL=info

# Optional: map weather via `/v2/map/current-weather` uses OpenWeather (recommended for production / commercial apps).
# When unset, Backendv2 uses Open-Meteo (free non-commercial API — fine for dev / internal builds).
# OPENWEATHER_API_KEY=

# Logs per-post media URLs/shape on feed surfaces (heavy). Also accepts LOCAVA_VIDEO_MEDIA_DEBUG=1.
# LOCAVA_FEED_ITEMS_MEDIA_TRACE=1

############################################
# 🪵 CLIENT DEBUG LOG INGEST (local-only, opt-in)
############################################
# Enables POST /v2/debug/client-logs so a production-profile native build
# pointed at this Backendv2 can stream startup/network/screen latency logs to
# the local terminal. Disabled by default. Never enable in deployed production.
# When unset, the route returns 404 and prints nothing.
# ENABLE_CLIENT_DEBUG_LOG_INGEST=1
# Optional cap (bytes) per batch. Default 65536; clamps to [1024, 524288].
# CLIENT_DEBUG_LOG_MAX_BATCH_BYTES=65536

############################################
# 🎬 VIDEO WORKER (Cloud Tasks POST target)
############################################
# Local-only API: point at yourself (sync / local task emulation if any).
# If your machine enqueues real GCP Cloud Tasks, use your deployed Cloud Run URL + /video-processor.
VIDEO_PROCESSOR_FUNCTION_URL=http://127.0.0.1:8080/video-processor

# Optional: lock down POST /video-processor (Cloud Tasks sends this header when set).
# VIDEO_PROCESSOR_TASK_SECRET=

# Post-upload Wasabi/S3 moov verification (HEAD/Range/Get). Default off — worker trusts local ffmpeg verify after PUT (verifyLocalMoov in encoding pipeline).
# Set to 1 to re-enable strict remote checks (same S3 lab + HTTPS fallback path).
# VIDEO_ENABLE_REMOTE_UPLOAD_VERIFY=1

############################################
# Firebase Authentication (needed for POST /v2/auth/*)
############################################

# Web API Key from Firebase console → Project settings → Your apps (must match Locava Native / web client).
FIREBASE_WEB_API_KEY=

# Matches the Firebase/GCP project that holds Auth + Firestore.
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=

# Firebase Admin JSON path (firebase-adminsdk-*), NOT analytics-only keys. `npm run dev` reads this from .env — no need to export in the shell.
# Example: GOOGLE_APPLICATION_CREDENTIALS=$HOME/Documents/locava-firebase-admin.json
GOOGLE_APPLICATION_CREDENTIALS=
# If your shell still exports a stale GOOGLE_APPLICATION_CREDENTIALS, Backendv2 (development) prefers the merged
# `.env` / `.env.local` path when that file exists. Set to 1 only if you intentionally want the shell value to win.
# KEEP_SHELL_GOOGLE_APPLICATION_CREDENTIALS=1

# Passed to Identity Toolkit `createAuthUri` + `signInWithIdp` as OAuth continue/request URI host.
# Add matching hosts under Firebase Authentication → Settings → Authorized domains (localhost + 127.0.0.1 + LAN IP + Cloud Run hostnames).
FIREBASE_AUTH_CONTINUE_URI=http://127.0.0.1:8080/auth/callback

# Optional labels for Apple audience mismatch diagnostics (match Apple Developer + Firebase).
# APPLE_IOS_BUNDLE_ID=com.judsondunne.locava
# APPLE_WEB_SERVICES_ID=com.judsondunne.locava.web

# Classic Express monolith (upload notifications + staged post creation proxies). Leave unset locally unless you deliberately forward there.
LEGACY_MONOLITH_PROXY_BASE_URL=

# Explicit public Backendv2 origin (deployed Cloud Run URL or http://LAN-IP:8080): used to WARN if LEGACY_MONOLITH_PROXY_BASE_URL aliases the same origin.
BACKEND_PUBLIC_BASE_URL=

# Emit `appPost` (locava.appPost v2) on postcards built via `buildPostEnvelope` / `toFeedCardDTO`. Set 0/false to disable.
# BACKEND_APP_POST_V2_RESPONSES=true

############################################
# Firebase read containment (deny-by-default)
############################################
# LOCAVA_FIREBASE_ACCESS_MODE=locked_down
# DISABLE_LEGACY_FIREBASE=true
# DISABLE_LEGACY_WORKERS=true
# DISABLE_LEGACY_CRON=true
# DISABLE_LEGACY_LISTENERS=true
# DISABLE_LEGACY_ANALYTICS_FIRESTORE=true
# DISABLE_LEGACY_FEED_FIRESTORE=true
# DISABLE_LEGACY_SEARCH_FIRESTORE=true
# DISABLE_LEGACY_PROFILE_FIRESTORE=true
# DISABLE_LEGACY_POST_FIRESTORE=true
# DISABLE_LEGACY_NOTIFICATIONS_FIRESTORE=true
# DISABLE_LEGACY_MAP_FIRESTORE=true
# DISABLE_LEGACY_REELS_FIRESTORE=true
# DISABLE_LEGACY_USERS_FIRESTORE=true
# DISABLE_LEGACY_COLLECTIONS_FIRESTORE=true
# ALLOW_BACKEND_V2_FIREBASE=true
# ALLOW_WIKIMEDIA_MVP_FIREBASE=true
# ALLOW_WIKIMEDIA_STAGING_FIREBASE=true

############################################
# Wikimedia MVP dev-only analysis page
############################################
# ENABLE_WIKIMEDIA_MVP_DEV_PAGE=true
# WIKIMEDIA_MVP_ALLOW_WRITES=false
# WIKIMEDIA_MVP_ENABLE_FIRESTORE_DEDUPE=false
# WIKIMEDIA_MVP_MAX_PLACES_PER_RUN=10
# WIKIMEDIA_MVP_MAX_CANDIDATES_PER_PLACE=200
# WIKIMEDIA_MVP_MAX_SEARCH_PAGES_PER_PLACE=25
# WIKIMEDIA_MVP_MAX_HYDRATE_TITLES_PER_PLACE=500
# WIKIMEDIA_MVP_FETCH_ALL_MAX_CANDIDATES_PER_PLACE=500
# WIKIMEDIA_MVP_FETCH_ALL_MAX_SEARCH_PAGES=100
# WIKIMEDIA_MVP_PLACE_TIMEOUT_MS=300000
# ENABLE_PLACE_CANDIDATE_DEV_PAGE=true
# ENABLE_STATE_CONTENT_FACTORY_DEV_PAGE=true
# STATE_CONTENT_FACTORY_ALLOW_STAGING_WRITES=false
# ALLOW_BACKEND_V2_MONOLITH_PROXY=true
# ENABLE_FIREBASE_ACCESS_POLICY_LOGS=true
# ENABLE_FIREBASE_ACCESS_DEBUG_ENDPOINT=false

############################################
# Analytics → BigQuery (legacy Locava Backend parity)
############################################
# Legacy monolith (`Locava Backend/src/services/analytics/bigqueryWriter.ts`) used:
#   GCP_PROJECT_ID || GOOGLE_CLOUD_PROJECT, ANALYTICS_DATASET (default analytics_prod),
#   ANALYTICS_EVENTS_TABLE (default client_events), and ADC via GOOGLE_APPLICATION_CREDENTIALS.
# Backendv2 matches that table resolution but should use a **dedicated** analytics writer key
# so Firebase Admin stays on firebase-adminsdk-* only:
#
# ANALYTICS_BIGQUERY_PROJECT_ID=learn-32d72
# ANALYTICS_BIGQUERY_DATASET=analytics_prod
# ANALYTICS_BIGQUERY_TABLE=client_events
# ANALYTICS_BIGQUERY_SERVICE_ACCOUNT_FILE=/absolute/path/to/analytics-writer-sa.json
#
# Optional inline JSON instead of file:
# ANALYTICS_BIGQUERY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# If unset, Backendv2 falls back to GOOGLE_APPLICATION_CREDENTIALS (same as old backend) and logs warnings at startup.
# ANALYTICS_ENABLED=true
# ANALYTICS_DATASET=analytics_prod
# ANALYTICS_EVENTS_TABLE=client_events

############################################
# Reels MVP publisher (Backendv2 `/internal/admin/reels-mvp-publisher/*`)
############################################
# REELS_MVP_PUBLISHER_ENABLED=true
# REELS_MVP_PUBLISHER_WRITE_ENABLED=true
# Post single-video repair UI: /internal/admin/post-single-video-repair/ui (needs ENABLED; WRITE_ENABLED is for batch reels publisher only)
# REELS_MVP_PUBLISHER_MAX_BATCH=1
# REELS_MVP_PUBLISHER_REQUIRE_READY=true
